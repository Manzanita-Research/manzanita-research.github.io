---
import ThemeToggle from "./ThemeToggle.astro";
---

<nav class="fixed top-0 right-0 left-0 z-50 bg-[var(--bg-page)]/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5 md:px-8">
    <a
      href="/"
      class="font-display text-lg tracking-tight text-[var(--text-primary)] transition-opacity hover:opacity-70"
      style="font-variation-settings: 'WONK' 1, 'SOFT' 50"
    >
      Manzanita Research
    </a>
    <div class="flex items-center gap-4">
      <a
        href="#work"
        class="hidden text-sm font-semibold text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)] md:block"
      >
        Work
      </a>
      <a
        href="#values"
        class="hidden text-sm font-semibold text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)] md:block"
      >
        Values
      </a>
      <a
        href="/projects"
        class="hidden text-sm font-semibold text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)] md:block"
      >
        Projects
      </a>
      <a
        href="/farm-stand"
        class="hidden text-sm font-semibold text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)] md:block"
      >
        Farm Stand
      </a>
      <a
        href="https://github.com/manzanita-research"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-semibold text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)]"
      >
        GitHub
      </a>
      <ThemeToggle />
    </div>
  </div>
</nav>
