---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--border-color)] px-6 py-16 md:px-8">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <p
          class="font-display text-lg text-[var(--text-primary)]"
          style="font-variation-settings: 'WONK' 1, 'SOFT' 50"
        >
          Manzanita Research
        </p>
        <p class="mt-2 text-sm text-[var(--text-secondary)]">
          With love from California
        </p>
      </div>
      <div>
        <p class="mb-3 font-mono text-xs uppercase tracking-widest text-[var(--text-secondary)]">
          Links
        </p>
        <div class="flex flex-col gap-2">
          <a
            href="/projects"
            class="text-sm text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)]"
          >
            Projects
          </a>
          <a
            href="/farm-stand"
            class="text-sm text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)]"
          >
            Farm Stand
          </a>
          <a
            href="https://github.com/manzanita-research"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)]"
          >
            GitHub
          </a>
        </div>
      </div>
      <div>
        <p class="mb-3 font-mono text-xs uppercase tracking-widest text-[var(--text-secondary)]">
          Ethos
        </p>
        <p class="text-sm leading-relaxed text-[var(--text-secondary)]">
          Local-first. Open where it matters.
          <br />
          No data collection. No subscriptions.
          <br />
          Instruments, not automations.
        </p>
      </div>
    </div>
    <div class="mt-16 border-t border-[var(--border-color)] pt-8">
      <p class="text-xs text-[var(--text-secondary)] opacity-60">
        &copy; {year} Manzanita Research
      </p>
    </div>
  </div>
</footer>
